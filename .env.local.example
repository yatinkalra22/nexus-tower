# Turso (libSQL) - create a database in the Turso dashboard, then copy the URL and auth token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Clerk Auth - create an application in the Clerk dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# AWS Bedrock - use IAM credentials for a user or role with Bedrock access
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# aisstream.io - create a free account and copy the WebSocket API key
AISSTREAM_API_KEY=

# OpenRouteService (optional) - only needed if you enable routing features
OPENROUTESERVICE_API_KEY=

# WITS (optional) - only needed if you use tariff lookups that require a higher quota
WITS_USER_NAME=

# Vercel Cron - choose a secure random secret and use the same value in Vercel
CRON_SECRET=
